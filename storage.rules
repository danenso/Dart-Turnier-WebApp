rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /avatars/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 2 * 1024 * 1024
        && request.resource.contentType.matches('image/(webp|avif|jpeg|png)');
      allow delete: if request.auth != null;
    }

    match /banners/{ligaId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 50 * 1024 * 1024
        && (request.resource.contentType.matches('image/.*') || request.resource.contentType.matches('video/.*'));
      allow delete: if request.auth != null;
    }

    match /songs/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.resource.size < 20 * 1024 * 1024
        && request.resource.contentType == 'audio/mpeg';
      allow delete: if request.auth != null;
    }
  }
}
