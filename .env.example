# ==============================================================
# Dart-Turnier-WebApp – Umgebungsvariablen
# Kopiere diese Datei als .env.local und trage deine Werte ein.
# .env.local wird NICHT in Git committed (steht in .gitignore).
# ==============================================================

# --- App-URL ---
# Lokal: http://localhost:3000
# Produktion: https://deine-domain.de
APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Admin-Konto ---
# Firebase UID und E-Mail des Admin-Benutzers (sichtbar im Client)
NEXT_PUBLIC_ADMIN_EMAIL="admin@example.com"
NEXT_PUBLIC_ADMIN_UID="FIREBASE_UID_DES_ADMINS"

# --- Gemini AI ---
# API-Key für Gemini AI-Funktionen (Google AI Studio)
GEMINI_API_KEY="DEIN_GEMINI_API_KEY"

# --- SMTP (E-Mail-Versand für Einladungen) ---
# Beispiel Hostinger: SMTP_HOST=smtp.hostinger.com, PORT=587
# Beispiel Gmail:     SMTP_HOST=smtp.gmail.com,      PORT=587
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="deine@email.de"
SMTP_PASS="DEIN_SMTP_PASSWORT"
SMTP_FROM="Dart Liga <deine@email.de>"
